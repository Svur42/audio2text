{
  "name": "audio2text",
  "version": "0.9.0",
  "description": "音频转文字桌面工具 — 本地 Whisper 转写，零 token",
  "main": "main.js",
  "author": "Svur42",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.user.audio2text",
    "productName": "Audio2Text",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "build/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "backend", "to": "backend" },
      { "from": "locales", "to": "locales" }
    ],
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "unpackDirName": "Audio2Text"
    }
  }
}
