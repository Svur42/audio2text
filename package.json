{
  "name": "audio2text",
  "version": "0.9.0",
  "description": "音频转文字桌面工具 — 本地 Whisper 转写，零 token",
  "main": "main.js",
  "author": "Svur42",
  "license": "GPL-3.0",
  "scripts": {
    "start": "electron .",
    "setup-python": "node scripts/setup-python-embed.js",
    "prebuild": "node scripts/setup-python-embed.js && rm -f dist/*.nsis.7z",
    "build": "electron-builder --win nsis",
    "build-portable": "electron-builder --win portable",
    "build-zip": "electron-builder --win zip"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.user.audio2text",
    "productName": "Audio2Text",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "build/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "locales",
        "to": "locales"
      },
      {
        "from": "build/python-embed",
        "to": "python-embed"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Audio2Text"
    },
    "portable": {
      "unpackDirName": "Audio2Text"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4"
  }
}
